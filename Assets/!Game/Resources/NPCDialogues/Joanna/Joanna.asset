  m_Script: {fileID: 11500000, guid: 7f2a72aeb33766d42868f6d9de333142, type: 3}
  m_Name: Joanna
  m_EditorClassIdentifier: 
  npcName: Joanna
  npcPortrait: {fileID: 1836460928, guid: 66b6bce819e37ab4b93337da3099348d, type: 3}
  dialogueLines:
  - "Ch\xE0o l\u1EEF kh\xE1ch. \u0110\xE2y kh\xF4ng ph\u1EA3i v\xF9ng \u0111\u1EA5t
    an to\xE0n cho k\u1EBB thi\u1EBFu chu\u1EA9n b\u1ECB. Ta l\xE0 Joanna, ng\u01B0\u1EDDi
    b\u1EA3o v\u1EC7 l\xE0ng n\xE0y. Ng\u01B0\u01A1i t\u1EEB \u0111\xE2u \u0111\u1EBFn?"
  - "M\u1ED9t l\u1EEF kh\xE1ch \u0111\u01A1n \u0111\u1ED9c \xE0? H\xE3y c\u1EA9n
    tr\u1ECDng \u2014 r\u1EEBng ph\xEDa b\u1EAFc \u0111\u1EA7y r\u1EABy b\u1ECDn
    ma v\u1EADt. Nh\u01B0ng n\u1EBFu ng\u01B0\u01A1i bi\u1EBFt d\xF9ng ki\u1EBFm...
    ta c\xF3 th\u1EC3 c\xF3 vi\u1EC7c cho ng\u01B0\u01A1i."
  - "T\u1ED1t. Tinh th\u1EA7n nh\u01B0 v\u1EADy ta c\u1EA7n. M\u1EA5y \u0111\xEAm
    nay, tr\u1EBB con trong l\xE0ng b\u1ECB \xE1m trong gi\u1EA5c m\u01A1, kh\xF4ng
    t\u1EC9nh d\u1EADy n\u1ED5i. Ng\u01B0\u1EDDi gi\xE0 k\u1EC3 r\u1EB1ng h\u1ED3n
    ma c\u1ED5 x\u01B0a t\u1EEB t\xE0n t\xEDch ph\xEDa b\u1EAFc \u0111ang th\u1EE9c
    gi\u1EA5c."
  - "Ta mu\u1ED1n ng\u01B0\u01A1i \u0111i \u0111i\u1EC1u tra t\xE0n t\xEDch \u0111\xF3.
    N\u1EBFu th\u1EA5y g\xEC b\u1EA5t th\u01B0\u1EDDng \u2014 \u0111\u1EB7c bi\u1EC7t
    l\xE0 d\u1EA5u hi\u1EC7u c\u1EE7a t\xE0 thu\u1EADt \u2014 h\xE3y quay l\u1EA1i
    b\xE1o cho ta."
  - "Ta hi\u1EC3u. Kh\xF4ng ph\u1EA3i ai c\u0169ng mu\u1ED1n k\xE9o l\u01B0\u1EE1i
    ki\u1EBFm v\xEC m\u1ED9t l\xE0ng xa l\u1EA1."
  - "Ng\u01B0\u01A1i v\u1EABn c\xF2n \u1EDF \u0111\xE2y \xE0? \u0110\xE1m ma v\u1EADt
    kh\xF4ng t\u1EF1 bi\u1EBFn m\u1EA5t \u0111\xE2u. D\xE2n l\xE0ng v\u1EABn ch\u1EDD
    m\u1ED9t tia hy v\u1ECDng..."
  - "N\u1EBFu ng\u01B0\u01A1i c\u1EA7n l\u1EDDi khuy\xEAn: \u0111\u1EEBng \u0111i
    m\u1ED9t m\xECnh v\xE0o r\u1EEBng s\xE2u l\xFAc ch\u1EA1ng v\u1EA1ng."
  - "Ng\u01B0\u01A1i tr\u1EDF l\u1EA1i r\u1ED3i... v\xE0 c\xF2n s\u1ED1ng."
  - "V\u1EBFt m\xE1u kia kh\xF4ng ph\u1EA3i c\u1EE7a ng\u01B0\u01A1i, \u0111\xFAng
    kh\xF4ng? T\u1ED1t."
  - "C\u1EA3 l\xE0ng s\u1EBD mang \u01A1n ng\u01B0\u01A1i. \u0110\xE2y l\xE0 ph\u1EA7n
    th\u01B0\u1EDFng nh\u1ECF \u2014 t\u1EEB l\xF2ng bi\u1EBFt \u01A1n ch\xE2n th\xE0nh."
  - "Nh\u01B0ng h\xE3y nh\u1EDB: chi\u1EBFn th\u1EAFng h\xF4m nay ch\u1EC9 l\xE0
    t\u1EA1m th\u1EDDi. Ch\xFAng s\u1EBD quay l\u1EA1i..."
  autoProgressLines: 0101010101010101010101
  endDialogueLines: 0000000001000100000001
  autoProgressDelay: 1.5
  typingSpeed: 0.05
  choices:
  - dialogueIndex: 0
    choices:
    - "\u201CT\xF4i ch\u1EC9 l\xE0 m\u1ED9t ng\u01B0\u1EDDi l\u1EEF h\xE0nh, \u0111i
      ngang qua.\u201D"
    nextDialogueIndexes: 01000000
    endDialogues: 
    specialActions: 
    specialTargetNames: []
    giveQuest: 
  - dialogueIndex: 1
    choices:
    - "\u201CT\xF4i kh\xF4ng s\u1EE3 ma v\u1EADt. C\xF3 chuy\u1EC7n g\xEC v\u1EADy?\u201D"
    - "\u201CT\xF4i ch\u1EC9 mu\u1ED1n ngh\u1EC9 ng\u01A1i, kh\xF4ng d\xEDnh l\xEDu
      v\xE0o r\u1EAFc r\u1ED1i.\u201D"
    - "\u201CMa v\u1EADt? \xDD c\xF4 l\xE0 l\u0169 n\xE0o?\u201D"
    nextDialogueIndexes: 020000000400000002000000
    endDialogues: 
    specialActions: 
    specialTargetNames: []
