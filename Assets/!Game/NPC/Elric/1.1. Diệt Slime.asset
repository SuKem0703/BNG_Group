  m_Script: {fileID: 11500000, guid: 59b366e6022b8614985e2aa3d435fb24, type: 3}
  m_Name: "1.1. Di\u1EC7t Slime"
  m_EditorClassIdentifier: Assembly-CSharp::MonologueData
  typingSpeed: 0.05
  dialogueLines:
  - "L\u1EA1i l\xE0 b\u1ECDn Slime n\xE0y! Ch\xFAng \u0111ang b\u1EAFt \u0111\u1EA7u
    x\u1EDBi tung khu v\u01B0\u1EDDn l\xEAn r\u1ED3i."
  - "Ch\u1EBFt th\u1EADt, m\xECnh ra v\u1ED9i qu\xE1 n\xEAn qu\xEAn mang theo v\u0169
    kh\xED. Tay kh\xF4ng th\xEC kh\xF4ng th\u1EC3 \u0111u\u1ED5i ch\xFAng \u0111i
    \u0111\u01B0\u1EE3c."
  - "Ph\u1EA3i quay v\u1EC1 nh\xE0 l\u1EA5y thanh ki\u1EBFm c\u0169 ra \u0111\xE2y
    nhanh th\xF4i!"
