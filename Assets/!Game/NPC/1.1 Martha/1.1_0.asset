    specialTargetNames: []
    giveQuest: 
  - dialogueIndex: 1
    choices:
    - "V\xE2ng, v\xE2ng... L\u1EA1i l\xE0 m\u1ED9t ng\xE0y loanh quanh v\u1EDBi ru\u1ED9ng
      v\u01B0\u1EDDn."
    nextDialogueIndexes: 
