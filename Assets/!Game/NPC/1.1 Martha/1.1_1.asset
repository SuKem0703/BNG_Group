  m_Script: {fileID: 11500000, guid: 7f2a72aeb33766d42868f6d9de333142, type: 3}
  m_Name: 1.1_1
  m_EditorClassIdentifier: Assembly-CSharp::NPCDialogue
  npcName: Martha
  npcPortrait: {fileID: 222144225264086075, guid: 546d5a915985c3349a0997bfff98b79e, type: 3}
  dialogueLines:
  - "Elric, d\u1EADy r\u1ED3i \xE0? Tranh th\u1EE7 tr\u1EDDi \u0111ang \u0111\u1EB9p,
    m\u1EB9 mu\u1ED1n tr\u1ED3ng th\xEAm \xEDt Hoa H\u01B0\u1EDBng D\u01B0\u01A1ng
    ngo\xE0i v\u01B0\u1EDDn. Con gi\xFAp m\u1EB9 m\u1ED9t tay \u0111\u01B0\u1EE3c
    kh\xF4ng?"
  - "Trong c\xE1i r\u01B0\u01A1ng g\u1ED7 \u1EDF g\xF3c nh\xE0. C\xE1i n\u1EAFp h\u01A1i
    k\xEAu, nh\u01B0ng v\u1EABn m\u1EDF \u0111\u01B0\u1EE3c. Con l\u1EA1i l\u1EA5y
    gi\xFAp m\u1EB9."
  - "M\u1EB9 \u1EDF trong nh\xE0 chu\u1EA9n b\u1ECB \xEDt \u0111\u1ED3. Con l\xE0m
    xong th\xEC g\u1ECDi m\u1EB9."
  autoProgressLines: 010101
  endDialogueLines: 000001
  autoProgressDelay: 1.5
  typingSpeed: 0.05
  choices:
  - dialogueIndex: 0
    choices:
    - "\u0110\u01B0\u1EE3c ch\u1EE9 m\u1EB9. H\u1EA1t gi\u1ED1ng m\u1EB9 \u0111\u1EC3
      ch\u1ED7 n\xE0o?"
    nextDialogueIndexes: 01000000
    endDialogues: 
    specialActions: 
    specialTargetNames: []
    giveQuest: 
  - dialogueIndex: 1
    choices:
    - "V\xE2ng, con hi\u1EC3u r\u1ED3i. Con l\xE0m ngay \u0111\xE2y."
    nextDialogueIndexes: 
    endDialogues: 01
